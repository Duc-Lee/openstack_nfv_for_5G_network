groups:
- name: 5g-core-alerts
  rules:
  - alert: ServiceDown
    expr: up == 0
    for: 1m
    labels:
      severity: critical
    annotations:
      summary: "Service {{ $labels.instance }} is down"
      description: "{{ $labels.instance }} of job {{ $labels.job }} has been down for more than 1 minute."

  - alert: HighRequestRate
    expr: rate(amf_requests_total[1m]) > 100
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: "High request rate on AMF"
      description: "AMF request rate is above 100 req/s (current: {{ $value }})."
